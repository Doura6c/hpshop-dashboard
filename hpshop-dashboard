    </div></td>
  </tr>`).join("");
}

function filterAll(q){renderAllOrders(q?orders.filter(o=>o.client.toLowerCase().includes(q.toLowerCase())||o.id.includes(q)):orders);}
function filterAllStatus(s){renderAllOrders(s==="all"?orders:orders.filter(o=>o.statut===s));}
function filterAllAgent(a){renderAllOrders(a==="all"?orders:orders.filter(o=>o.agent===a));}
function filterAllCity(c){renderAllOrders(c==="all"?orders:orders.filter(o=>o.ville===c));}

function populateAgentFilter(){
  const sel=document.getElementById("agentFilter");
  if(!sel)return;
  AGENTS.forEach(a=>{const opt=document.createElement("option");opt.value=a.id;opt.textContent=a.name;sel.appendChild(opt);});
}

// ══════════════════════════════════════════
// AGENT VIEW
// ══════════════════════════════════════════
function setupAgent(){
  document.getElementById("sbNav").innerHTML=`
    <div class="sb-sec">Mes commandes</div>
    <div class="sb-link on" onclick="showPg('agent-home',this)"><span class="sb-ico">📦</span>Mes commandes affectées<span class="sb-badge" id="myBadge">0</span></div>`;
  showPg("agent-home",null);
  renderAgentKanban();
}

function renderAgentKanban(){
