  }).join("");
}

// ══════════════════════════════════════════
// SUPERVISEUR VIEW
// ══════════════════════════════════════════
function setupSuper(){
  document.getElementById("sbNav").innerHTML=`
    <div class="sb-sec">Supervision</div>
    <div class="sb-link on" onclick="showPg('super',this)"><span class="sb-ico">📊</span>Vue globale</div>`;
  showPg("super",null);
  renderSuper();
}

function renderSuper(){
  const total=orders.length;
  const livrees=orders.filter(o=>o.statut==="Livrée").length;
  const pb=orders.filter(o=>["Injoignable","Annulée","Reportée"].includes(o.statut)).length;
  const ca=orders.filter(o=>o.statut==="Livrée").reduce((s,o)=>s+o.prix,0);
  const taux=Math.round(livrees/total*100);

  document.getElementById("superStats").innerHTML=`
    <div class="sc sc-blue"><div class="sc-ico">📦</div><div class="sc-val">${total}</div><div class="sc-lbl">Total</div></div>
    <div class="sc sc-green"><div class="sc-ico">📬</div><div class="sc-val">${livrees}</div><div class="sc-lbl">Livrées</div><div class="sc-trend up">↑ ${taux}% taux</div></div>
    <div class="sc sc-red"><div class="sc-ico">⚠️</div><div class="sc-val">${pb}</div><div class="sc-lbl">Problèmes</div></div>
    <div class="sc sc-gold"><div class="sc-ico">💰</div><div class="sc-val">${(ca/1000000).toFixed(1)}M</div><div class="sc-lbl">CA GNF</div></div>
    <div class="sc sc-purple"><div class="sc-ico">👥</div><div class="sc-val">${AGENTS.length}</div><div class="sc-lbl">Agents actifs</div></div>`;

  // Perf agents
  document.getElementById("superPerf").innerHTML=AGENTS.map(a=>{
    const mes=orders.filter(o=>o.agent===a.id);
    const liv=mes.filter(o=>o.statut==="Livrée").length;
    const tx=mes.length?Math.round(liv/mes.length*100):0;
    const initials=a.name.split(" ").map(n=>n[0]).join("").slice(0,2);
    return `<div class="perf-card">
      <div class="perf-av" style="background:linear-gradient(135deg,${a.color},${a.color}88)">${initials}</div>
      <div class="perf-name">${a.name}</div>
      <div class="perf-bar-wrap"><div class="perf-bar" style="width:${tx}%"></div></div>
      <div class="perf-stat"><span>${mes.length} cmd</span><span style="color:var(--green)">${tx}% livrées</span></div>
    </div>`;
  }).join("");

  // Commandes critiques
  const critical=orders.filter(o=>["Injoignable","Reportée","Annulée"].includes(o.statut)).slice(0,8);
  const st=s=>STATUTS_ALL.find(x=>x.key===s)||{label:s,cls:"b-new"};
  document.getElementById("criticalTbl").innerHTML=critical.map(o=>`<tr>
    <td><b style="color:var(--red)">${o.id}</b></td>
    <td>${o.client}</td>
    <td><span class="badge ${st(o.statut).cls}">${st(o.statut).label}</span></td>
    <td style="font-size:.75rem">${o.agentName||"—"}</td>
    <td><button class="btn btn-outline" style="font-size:.62rem;padding:4px 8px" onclick="openStatus('${o.id}')">✏️ Intervenir</button></td>
  </tr>`).join("");

  // Vue globale
  document.getElementById("superAllTbl").innerHTML=orders.map(o=>`<tr>
    <td><b style="color:var(--red)">${o.id}</b></td>
    <td>${o.client}</td>
    <td style="font-size:.78rem">${o.emoji} ${o.produit}</td>
    <td style="font-size:.75rem">${o.agentName||"<i style='color:var(--muted)'>Non affecté</i>"}</td>
    <td><span class="badge ${st(o.statut).cls}">${st(o.statut).label}</span></td>
    <td style="font-family:Bebas Neue,sans-serif">${o.prix.toLocaleString("fr")} GNF</td>
    <td><button class="btn btn-outline" style="font-size:.62rem;padding:4px 8px" onclick="openStatus('${o.id}')">✏️</button></td>
  </tr>`).join("");
}

// ══════════════════════════════════════════
// STOCK & PERF
// ══════════════════════════════════════════
const stockData=[
  {nom:"Fer à Lisser Pro",emoji:"💇‍♀️",qty:15},{nom:"Montre GPS",emoji:"⌚",qty:8},
  {nom:"Climatiseur",emoji:"❄️",qty:3},{nom:"Drone 4K",emoji:"🚁",qty:5},
  {nom:"Robot Cuiseur",emoji:"🍳",qty:12},{nom:"Blender Pro",emoji:"🥤",qty:0},
  {nom:"Purificateur Air",emoji:"💨",qty:7},{nom:"Masseur Pistolet",emoji:"💪",qty:2},
  {nom:"Vélo Appartement",emoji:"🚴",qty:4},{nom:"Kit Soin Visage",emoji:"✨",qty:20},
];

function renderStock(){
  document.getElementById("stockGrid").innerHTML=stockData.map((s,i)=>{
    const c=s.qty===0?"var(--red)":s.qty<=4?"var(--orange)":"var(--green)";
    const t=s.qty===0?"❌ Rupture":s.qty<=4?"⚠️ Faible":"✅ OK";
    return `<div style="background:var(--bg);border:1.5px solid var(--border);border-radius:10px;padding:1.1rem;text-align:center;transition:all .3s;" onmouseover="this.style.borderColor='var(--red)'" onmouseout="this.style.borderColor='var(--border)'">
      <div style="font-size:2rem;margin-bottom:.4rem">${s.emoji}</div>
      <div style="font-weight:800;font-size:.8rem;margin-bottom:.3rem">${s.nom}</div>
      <div style="font-family:Bebas Neue,sans-serif;font-size:1.6rem;color:${c}">${s.qty}</div>
      <div style="font-size:.65rem;font-weight:800;color:${c};margin-bottom:.6rem">${t}</div>
      <div style="display:flex;justify-content:center;gap:.4rem;">
        <button style="width:26px;height:26px;border-radius:6px;border:1.5px solid var(--border);background:#fff;cursor:pointer;font-weight:800;font-size:.9rem" onclick="stockData[${i}].qty=Math.max(0,stockData[${i}].qty-1);renderStock()">−</button>
        <button style="width:26px;height:26px;border-radius:6px;border:1.5px solid var(--border);background:#fff;cursor:pointer;font-weight:800;font-size:.9rem" onclick="stockData[${i}].qty++;renderStock()">+</button>
        ${s.qty<=4?`<button class="btn btn-red" style="font-size:.6rem;padding:3px 7px" onclick="toast('📲 Alerte stock envoyée !','warn')">📲</button>`:""}
      </div>
    </div>`;
  }).join("");
}

function renderPerf(){
  document.getElementById("perfGrid").innerHTML=AGENTS.map(a=>{
    const mes=orders.filter(o=>o.agent===a.id);
    const liv=mes.filter(o=>o.statut==="Livrée").length;
    const tx=mes.length?Math.round(liv/mes.length*100):0;
    const initials=a.name.split(" ").map(n=>n[0]).join("").slice(0,2);
    return `<div class="perf-card">
      <div class="perf-av" style="background:linear-gradient(135deg,${a.color},${a.color}88)">${initials}</div>
      <div class="perf-name">${a.name}</div>
      <div style="font-size:.72rem;color:var(--muted);margin-bottom:.5rem">${a.id}</div>
      <div class="perf-bar-wrap"><div class="perf-bar" style="width:${tx}%"></div></div>
      <div class="perf-stat"><span>${mes.length} commandes</span><span style="color:var(--green)">${tx}% livrées</span></div>
      <div style="margin-top:.6rem;display:flex;gap:.3rem;">
        <button class="btn btn-outline" style="font-size:.62rem;padding:4px 8px;flex:1" onclick="toast('💬 Message envoyé à ${a.name}','success')">💬 Contacter</button>
      </div>
    </div>`;
  }).join("");
}

// ══════════════════════════════════════════
// WHATSAPP
// ══════════════════════════════════════════
function sendWA(id){
  const o=orders.find(x=>x.id===id);
  if(!o)return;
  const msg=`🛍 *Commande HPSHOP ${o.id}*\n\n👤 ${o.client}\n📞 ${o.tel}\n📦 ${o.emoji} ${o.produit}\n💰 ${o.prix.toLocaleString("fr")} GNF\n📍 ${o.adresse}, ${o.ville}\n💳 ${o.paiement}\n📊 Statut : ${o.statut}\n${o.note?"📝 Note : "+o.note:""}\n\n⚡ Livraison via *Rapido*`;
  window.open(`https://wa.me/224XXXXXXXX?text=${encodeURIComponent(msg)}`,"_blank");
  toast("💬 Message WhatsApp ouvert !","success");
}

function exportWA(){
  const msg=`📊 *Rapport HPSHOP*\n\n📦 Total : ${orders.length}\n✅ Livrées : ${orders.filter(o=>o.statut==="Livrée").length}\n⚠️ Problèmes : ${orders.filter(o=>["Injoignable","Annulée"].includes(o.statut)).length}\n💰 CA : ${(orders.filter(o=>o.statut==="Livrée").reduce((s,o)=>s+o.prix,0)/1000000).toFixed(1)}M GNF`;
  window.open(`https://wa.me/224XXXXXXXX?text=${encodeURIComponent(msg)}`,"_blank");
}

function exportCSV(){
  const h="ID,Date,Client,Tel,Produit,Prix,Ville,Paiement,Agent,Statut,Note\n";
  const r=orders.map(o=>`${o.id},${o.date},${o.client},${o.tel},${o.produit},${o.prix},${o.ville},${o.paiement},${o.agentName||""},${o.statut},${o.note||""}`).join("\n");
  const b=new Blob([h+r],{type:"text/csv"});
  const a=document.createElement("a");a.href=URL.createObjectURL(b);a.download="hpshop-commandes.csv";a.click();
  toast("📥 Export CSV téléchargé !","success");
}

// ══════════════════════════════════════════
// NAVIGATION
// ══════════════════════════════════════════
function showPg(name,btn){
  document.querySelectorAll(".page").forEach(p=>p.classList.remove("on"));
  document.querySelectorAll(".sb-link").forEach(l=>l.classList.remove("on"));
  const pg=document.getElementById("pg-"+name);
  if(pg)pg.classList.add("on");
  if(btn)btn.classList.add("on");
  const titles={dashboard:"Tableau de bord — Manager","all":"Toutes les commandes",agents:"Performance agents",stock:"Gestion stock","agent-home":"Mes commandes",super:"Supervision globale"};
  document.getElementById("tbTitle").textContent=titles[name]||name;
}

function closeModals(){
  document.querySelectorAll(".overlay").forEach(o=>o.classList.remove("show"));
  pickedAgent=null; pickedStatus=null; targetOrderId=null;
}
document.querySelectorAll(".overlay").forEach(o=>o.addEventListener("click",function(e){if(e.target===this)closeModals();}));

// ══════════════════════════════════════════
// TOAST
// ══════════════════════════════════════════
let toastTimer;
function toast(msg,type="success"){
  const el=document.getElementById("toastEl");
  el.textContent=msg;
  el.className=`toast toast-${type} show`;
  clearTimeout(toastTimer);
  toastTimer=setTimeout(()=>el.classList.remove("show"),3500);
}

