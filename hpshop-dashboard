  const cols=[
    {key:"Affectée",label:"🎯 À traiter",color:"var(--blue)"},
    {key:"Confirmée",label:"✅ Confirmées",color:"var(--gold)"},
    {key:"En livraison",label:"🚚 En livraison",color:"var(--green)"},
    {key:"Reportée",label:"⏳ Reportées",color:"var(--orange)"},
    {key:"Injoignable",label:"📵 Injoignable",color:"var(--muted)"},
