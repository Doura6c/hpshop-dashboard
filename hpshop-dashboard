    <td style="font-size:.75rem">${o.agentName||"<i style='color:var(--muted)'>Non affecté</i>"}</td>
    <td><span class="badge ${st(o.statut).cls}">${st(o.statut).label}</span></td>
    <td style="font-size:.72rem;max-width:100px;overflow:hidden;text-overflow:ellipsis">${o.note||"—"}</td>
    <td><div style="display:flex;gap:.3rem;">
      ${o.statut==="Nouvelle"?`<button class="btn btn-gold" style="font-size:.62rem;padding:4px 8px" onclick="openAffect('${o.id}')">🎯</button>`:""}
