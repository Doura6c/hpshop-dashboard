<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>HPSHOP — Espace Gestion</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Bebas+Neue&display=swap');
:root{
  --red:#E8001C;--gold:#F5A800;--green:#1A8A2E;
  --blue:#3B82F6;--purple:#8B5CF6;--orange:#F97316;
  --bg:#F4F6FA;--white:#fff;--dark:#1a1a1a;
  --muted:#6b7280;--border:#E5E7EB;
  --shadow:0 2px 12px rgba(0,0,0,0.07);
  --shadow-lg:0 8px 30px rgba(0,0,0,0.12);
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:"Nunito",sans-serif;background:var(--bg);color:var(--dark);overflow-x:hidden;}

/* ── LOGIN ── */
.login-screen{position:fixed;inset:0;background:linear-gradient(135deg,#0a0a0a,#1a0800);display:flex;align-items:center;justify-content:center;z-index:9999;}
.login-box{background:#fff;border-radius:16px;padding:2.5rem;width:380px;box-shadow:0 25px 80px rgba(0,0,0,0.4);text-align:center;}
.login-logo{font-family:"Bebas Neue",sans-serif;font-size:2.2rem;color:var(--red);letter-spacing:3px;margin-bottom:.2rem;}
.login-sub{font-size:.78rem;color:var(--muted);margin-bottom:2rem;font-weight:600;}
.login-roles{display:grid;grid-template-columns:1fr 1fr;gap:.7rem;margin-bottom:1.5rem;}
.role-btn{padding:.8rem;border:2px solid var(--border);border-radius:10px;cursor:pointer;transition:all .3s;text-align:center;}
.role-btn:hover,.role-btn.selected{border-color:var(--red);background:rgba(232,0,28,.05);}
.role-btn .role-ico{font-size:1.5rem;display:block;margin-bottom:.3rem;}
.role-btn .role-name{font-size:.78rem;font-weight:800;color:var(--dark);}
.login-fg{margin-bottom:1rem;text-align:left;}
.login-fg label{font-size:.72rem;font-weight:800;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);display:block;margin-bottom:.35rem;}
.login-fg input{width:100%;padding:11px 14px;border:1.5px solid var(--border);border-radius:8px;font-family:"Nunito",sans-serif;font-size:.9rem;outline:none;transition:border-color .3s;}
.login-fg input:focus{border-color:var(--red);}
.login-btn{width:100%;background:var(--red);color:#fff;border:none;padding:13px;border-radius:8px;font-family:"Bebas Neue",sans-serif;font-size:1.2rem;letter-spacing:2px;cursor:pointer;transition:background .3s;}
.login-btn:hover{background:#b8001a;}
.demo-hint{font-size:.68rem;color:#ccc;margin-top:.8rem;}

/* ── LAYOUT ── */
.layout{display:grid;grid-template-columns:255px 1fr;min-height:100vh;}
.sidebar{background:#111;padding:0;position:sticky;top:0;height:100vh;overflow-y:auto;display:flex;flex-direction:column;}
.sb-logo{padding:1.5rem;border-bottom:1px solid rgba(255,255,255,.07);}
.sb-logo-txt{font-family:"Bebas Neue",sans-serif;font-size:1.6rem;color:var(--gold);letter-spacing:3px;}
.sb-logo-sub{font-size:.62rem;color:rgba(255,255,255,.35);letter-spacing:1.5px;text-transform:uppercase;margin-top:.1rem;}
.sb-user{padding:1rem 1.5rem;display:flex;align-items:center;gap:.8rem;border-bottom:1px solid rgba(255,255,255,.07);cursor:pointer;}
.sb-av{width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;color:#fff;font-size:.88rem;flex-shrink:0;}
.sb-av-manager{background:linear-gradient(135deg,var(--gold),#a06800);}
.sb-av-agent{background:linear-gradient(135deg,var(--red),#8b0000);}
.sb-av-super{background:linear-gradient(135deg,var(--purple),#5b21b6);}
.sb-uname{font-size:.82rem;font-weight:800;color:#fff;}
.sb-urole{font-size:.62rem;color:rgba(255,255,255,.4);margin-top:.1rem;}
.sb-online{display:flex;align-items:center;gap:.3rem;font-size:.62rem;color:#2ECC71;margin-top:.1rem;}
.sb-nav{padding:.8rem 0;flex:1;}
.sb-sec{font-size:.58rem;font-weight:800;letter-spacing:2.5px;text-transform:uppercase;color:rgba(255,255,255,.25);padding:.6rem 1.5rem;margin-top:.3rem;}
.sb-link{display:flex;align-items:center;gap:.8rem;padding:.7rem 1.5rem;color:rgba(255,255,255,.55);font-size:.82rem;font-weight:700;cursor:pointer;transition:all .2s;border-left:3px solid transparent;position:relative;}
.sb-link:hover,.sb-link.on{background:rgba(255,255,255,.05);color:#fff;border-left-color:var(--gold);}
.sb-ico{font-size:1rem;width:18px;text-align:center;}
.sb-badge{background:var(--red);color:#fff;font-size:.58rem;font-weight:800;padding:2px 7px;border-radius:10px;margin-left:auto;animation:badgePulse 2s ease infinite;}
@keyframes badgePulse{0%,100%{opacity:1}50%{opacity:.6}}
.sb-bot{padding:1rem 1.5rem;border-top:1px solid rgba(255,255,255,.07);}
.sb-logout{display:flex;align-items:center;gap:.6rem;color:rgba(255,255,255,.35);font-size:.78rem;cursor:pointer;transition:color .3s;}
.sb-logout:hover{color:var(--red);}

/* ── TOPBAR ── */
.main{overflow:hidden;display:flex;flex-direction:column;}
.topbar{background:#fff;border-bottom:1px solid var(--border);padding:0 2rem;height:62px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;box-shadow:var(--shadow);flex-shrink:0;}
.tb-title{font-family:"Bebas Neue",sans-serif;font-size:1.25rem;letter-spacing:1px;}
.tb-right{display:flex;align-items:center;gap:.8rem;}
.tb-role-tag{padding:5px 14px;border-radius:20px;font-size:.72rem;font-weight:800;text-transform:uppercase;letter-spacing:.5px;}
.tag-manager{background:rgba(245,168,0,.15);color:#a06800;}
.tag-agent{background:rgba(232,0,28,.1);color:var(--red);}
.tag-super{background:rgba(139,92,246,.1);color:var(--purple);}
.notif-btn{position:relative;background:var(--bg);border:1.5px solid var(--border);width:38px;height:38px;border-radius:8px;cursor:pointer;font-size:1rem;display:flex;align-items:center;justify-content:center;}
.notif-dot{position:absolute;top:5px;right:5px;width:8px;height:8px;background:var(--red);border-radius:50%;border:2px solid #fff;}

/* ── PAGES ── */
.page{display:none;padding:1.8rem;flex:1;overflow-y:auto;}
.page.on{display:block;}

/* ── STATS ── */
.stats-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:1rem;margin-bottom:1.8rem;}
.sc{background:#fff;border-radius:12px;padding:1.3rem;box-shadow:var(--shadow);border-top:3px solid transparent;transition:transform .3s;}
.sc:hover{transform:translateY(-3px);}
.sc-red{border-top-color:var(--red);}
.sc-gold{border-top-color:var(--gold);}
.sc-green{border-top-color:var(--green);}
.sc-blue{border-top-color:var(--blue);}
.sc-purple{border-top-color:var(--purple);}
.sc-ico{font-size:1.6rem;margin-bottom:.6rem;}
.sc-val{font-family:"Bebas Neue",sans-serif;font-size:2rem;line-height:1;color:var(--dark);}
.sc-lbl{font-size:.68rem;font-weight:800;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-top:.2rem;}
.sc-trend{font-size:.68rem;font-weight:700;margin-top:.3rem;}
.up{color:var(--green);}
.dn{color:var(--red);}

/* ── CARDS ── */
.card{background:#fff;border-radius:12px;box-shadow:var(--shadow);overflow:hidden;margin-bottom:1.2rem;}
.card-h{padding:1.1rem 1.5rem;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.5rem;}
.card-t{font-weight:800;font-size:.92rem;}
.card-acts{display:flex;gap:.5rem;align-items:center;}

/* ── BUTTONS ── */
.btn{padding:7px 16px;border-radius:7px;font-size:.75rem;font-weight:800;cursor:pointer;border:none;font-family:"Nunito",sans-serif;transition:all .3s;display:inline-flex;align-items:center;gap:.3rem;}
.btn-red{background:var(--red);color:#fff;}
.btn-red:hover{background:#b8001a;}
.btn-green{background:var(--green);color:#fff;}
.btn-green:hover{background:#146622;}
.btn-gold{background:var(--gold);color:#fff;}
.btn-gold:hover{background:#cc8c00;}
.btn-blue{background:var(--blue);color:#fff;}
.btn-purple{background:var(--purple);color:#fff;}
.btn-outline{background:transparent;border:1.5px solid var(--border);color:var(--muted);}
.btn-outline:hover{border-color:var(--red);color:var(--red);}

/* ── FILTERS ── */
.filters{display:flex;gap:.6rem;padding:1rem 1.5rem;border-bottom:1px solid var(--border);flex-wrap:wrap;align-items:center;}
.fi{padding:7px 12px;border:1.5px solid var(--border);border-radius:7px;font-family:"Nunito",sans-serif;font-size:.78rem;font-weight:700;outline:none;color:var(--dark);background:#fff;cursor:pointer;}
.fi:focus{border-color:var(--red);}
.search{width:200px;}

/* ── TABLE ── */
.tbl-wrap{overflow-x:auto;}
table{width:100%;border-collapse:collapse;font-size:.82rem;}
th{padding:.8rem 1rem;text-align:left;font-size:.65rem;font-weight:800;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);background:#FAFAFA;border-bottom:1px solid var(--border);white-space:nowrap;}
td{padding:.85rem 1rem;border-bottom:1px solid var(--border);vertical-align:middle;}
tr:last-child td{border-bottom:none;}
tr:hover td{background:#FAFBFF;}

/* ── STATUS BADGES ── */
.badge{display:inline-flex;align-items:center;gap:.25rem;padding:3px 10px;border-radius:20px;font-size:.66rem;font-weight:800;white-space:nowrap;}
.b-new{background:rgba(59,130,246,.12);color:#2563EB;}
.b-affect{background:rgba(139,92,246,.12);color:var(--purple);}
.b-confirm{background:rgba(245,168,0,.12);color:#D97706;}
.b-livraison{background:rgba(26,138,46,.12);color:var(--green);}
.b-livre{background:rgba(26,138,46,.2);color:var(--green);}
.b-reporte{background:rgba(249,115,22,.12);color:var(--orange);}
.b-annule{background:rgba(232,0,28,.12);color:var(--red);}
.b-injoignable{background:rgba(107,114,128,.12);color:var(--muted);}

/* ── PRIORITY ── */
.prio{display:inline-block;width:8px;height:8px;border-radius:50%;margin-right:.3rem;}
.prio-high{background:var(--red);}
.prio-mid{background:var(--gold);}
.prio-low{background:var(--green);}

/* ── AFFECTATION MODAL ── */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:1000;align-items:center;justify-content:center;backdrop-filter:blur(4px);}
.overlay.show{display:flex;}
.modal{background:#fff;border-radius:16px;padding:2rem;width:90%;box-shadow:0 25px 80px rgba(0,0,0,.25);animation:zi .3s ease;max-height:90vh;overflow-y:auto;}
.modal-sm{max-width:480px;}
.modal-lg{max-width:700px;}
.modal h3{font-family:"Bebas Neue",sans-serif;font-size:1.4rem;letter-spacing:1px;margin-bottom:1.2rem;color:var(--dark);display:flex;align-items:center;gap:.5rem;}
@keyframes zi{from{transform:scale(.9);opacity:0}to{transform:scale(1);opacity:1}}

.detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:.8rem;margin-bottom:1.2rem;}
.df label{font-size:.65rem;font-weight:800;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);display:block;margin-bottom:.2rem;}
.df span{font-size:.88rem;font-weight:700;color:var(--dark);}

.agent-select-grid{display:grid;grid-template-columns:1fr 1fr;gap:.8rem;margin-bottom:1.2rem;}
.agent-opt{border:2px solid var(--border);border-radius:10px;padding:1rem;cursor:pointer;transition:all .3s;display:flex;align-items:center;gap:.8rem;}
.agent-opt:hover,.agent-opt.picked{border-color:var(--gold);background:rgba(245,168,0,.05);}
.agent-opt-av{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;color:#fff;font-size:.8rem;flex-shrink:0;}
.agent-opt-name{font-weight:800;font-size:.82rem;}
.agent-opt-info{font-size:.68rem;color:var(--muted);}
.agent-opt-load{font-size:.68rem;font-weight:800;margin-top:.1rem;}

.status-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.6rem;margin-bottom:1rem;}
.status-opt{border:2px solid var(--border);border-radius:8px;padding:.7rem;cursor:pointer;transition:all .3s;text-align:center;font-size:.75rem;font-weight:800;}
.status-opt:hover{transform:scale(1.03);}
.so-confirm{border-color:var(--gold);color:var(--gold);}
.so-confirm:hover,.so-confirm.picked{background:var(--gold);color:#fff;}
.so-livre{border-color:var(--green);color:var(--green);}
.so-livre:hover,.so-livre.picked{background:var(--green);color:#fff;}
.so-reporte{border-color:var(--orange);color:var(--orange);}
.so-reporte:hover,.so-reporte.picked{background:var(--orange);color:#fff;}
.so-annule{border-color:var(--red);color:var(--red);}
.so-annule:hover,.so-annule.picked{background:var(--red);color:#fff;}
.so-injoignable{border-color:var(--muted);color:var(--muted);}
.so-injoignable:hover,.so-injoignable.picked{background:var(--muted);color:#fff;}
.so-livraison{border-color:var(--blue);color:var(--blue);}
.so-livraison:hover,.so-livraison.picked{background:var(--blue);color:#fff;}

.note-box{width:100%;padding:10px 14px;border:1.5px solid var(--border);border-radius:8px;font-family:"Nunito",sans-serif;font-size:.85rem;resize:vertical;min-height:70px;outline:none;margin-bottom:1rem;}
.note-box:focus{border-color:var(--gold);}
.modal-footer{display:flex;gap:.7rem;justify-content:flex-end;flex-wrap:wrap;}

/* ── AGENT VIEW ── */
.my-orders-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.2rem;}
.order-kanban{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.2rem;}
.kanban-col{background:var(--bg);border-radius:12px;padding:1rem;}
.kanban-col-h{font-weight:800;font-size:.85rem;margin-bottom:1rem;display:flex;align-items:center;justify-content:space-between;}
.kanban-cnt{font-size:.7rem;font-weight:800;padding:2px 8px;border-radius:10px;}
.order-mini{background:#fff;border-radius:10px;padding:1rem;margin-bottom:.7rem;border-left:3px solid transparent;box-shadow:var(--shadow);cursor:pointer;transition:all .3s;}
.order-mini:hover{transform:translateY(-2px);box-shadow:var(--shadow-lg);}
.om-id{font-size:.7rem;font-weight:800;color:var(--muted);}
.om-client{font-weight:800;font-size:.88rem;margin:.2rem 0;}
.om-produit{font-size:.78rem;color:var(--muted);}
.om-prix{font-family:"Bebas Neue",sans-serif;font-size:1.1rem;color:var(--red);margin-top:.3rem;}
.om-time{font-size:.65rem;color:var(--muted);margin-top:.2rem;}

/* ── SUPERVISOR ── */
.perf-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem;padding:1.2rem;}
.perf-card{background:#fff;border-radius:10px;padding:1.2rem;border:1.5px solid var(--border);box-shadow:var(--shadow);}
.perf-av{width:42px;height:42px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;color:#fff;font-size:.9rem;margin-bottom:.7rem;}
.perf-name{font-weight:800;font-size:.88rem;margin-bottom:.3rem;}
.perf-bar-wrap{background:var(--bg);border-radius:4px;height:6px;margin:.4rem 0 .2rem;}
.perf-bar{height:6px;border-radius:4px;background:linear-gradient(90deg,var(--green),var(--gold));transition:width .5s ease;}
.perf-stat{display:flex;justify-content:space-between;font-size:.68rem;color:var(--muted);font-weight:700;}

/* ── CHART ── */
.mini-chart{display:flex;align-items:flex-end;gap:.4rem;height:80px;padding:.5rem 1.5rem 0;}
.mc-bar-w{flex:1;display:flex;flex-direction:column;align-items:center;gap:.2rem;}
.mc-bar{width:100%;border-radius:3px 3px 0 0;transition:height .5s ease;min-height:3px;}
.mc-lbl{font-size:.58rem;color:var(--muted);font-weight:700;}

/* ── TOAST ── */
.toast{position:fixed;bottom:1.5rem;right:1.5rem;padding:.9rem 1.4rem;border-radius:10px;font-size:.83rem;font-weight:700;z-index:9999;display:none;align-items:center;gap:.6rem;box-shadow:var(--shadow-lg);animation:slideIn .3s ease;max-width:350px;}
.toast.show{display:flex;}
.toast-success{background:#111;color:#fff;}
.toast-warn{background:var(--orange);color:#fff;}
.toast-error{background:var(--red);color:#fff;}
@keyframes slideIn{from{transform:translateX(110%);opacity:0}to{transform:translateX(0);opacity:1}}

/* ── EMPTY ── */
.empty{text-align:center;padding:3rem;color:var(--muted);}
.empty-ico{font-size:3rem;margin-bottom:.8rem;}

@media(max-width:900px){
  .layout{grid-template-columns:1fr;}
  .sidebar{display:none;}
  .stats-grid{grid-template-columns:repeat(2,1fr);}
}
</style>
</head>
<body>

<!-- ══ LOGIN ══ -->
<div class="login-screen" id="loginScreen">
  <div class="login-box">
    <div class="login-logo">🏪 HPSHOP</div>
    <div class="login-sub">Espace de gestion interne</div>
    <div class="login-fg">
      <label>Identifiant</label>
      <input type="text" id="lu" placeholder="Ex: manager / agent01 / super">
    </div>
    <div class="login-fg">
      <label>Mot de passe</label>
      <input type="password" id="lp" placeholder="••••••••">
    </div>
    <button class="login-btn" onclick="doLogin()">ACCÉDER</button>
    <div class="demo-hint">
      👔 Manager : <b>manager</b> / <b>hp2026</b><br>
      🧑 Agent : <b>agent01</b> → <b>agent06</b> / <b>hp2026</b><br>
      📊 Superviseur : <b>super</b> / <b>hp2026</b>
    </div>
  </div>
</div>

<!-- ══ APP ══ -->
<div class="layout" id="app" style="display:none">

  <!-- SIDEBAR -->
  <div class="sidebar">
    <div class="sb-logo">
      <div class="sb-logo-txt">HPSHOP</div>
      <div class="sb-logo-sub">Espace Gestion</div>
    </div>
    <div class="sb-user">
      <div class="sb-av" id="sbAv"></div>
      <div>
        <div class="sb-uname" id="sbName"></div>
        <div class="sb-urole" id="sbRole"></div>
        <div class="sb-online">● En ligne</div>
      </div>
    </div>
    <div class="sb-nav" id="sbNav"></div>
    <div class="sb-bot">
      <div class="sb-logout" onclick="logout()">🚪 &nbsp;Déconnexion</div>
    </div>
  </div>

  <!-- MAIN -->
  <div class="main">
    <div class="topbar">
      <div class="tb-title" id="tbTitle">Tableau de bord</div>
      <div class="tb-right">
        <div class="tb-role-tag" id="tbRoleTag"></div>
        <button class="notif-btn" id="notifBtn">🔔<div class="notif-dot"></div></button>
      </div>
    </div>

    <!-- ══ MANAGER PAGES ══ -->

    <!-- Dashboard Manager -->
    <div class="page on" id="pg-dashboard">
      <div class="stats-grid" id="statsGrid"></div>
      <div style="display:grid;grid-template-columns:2fr 1fr;gap:1.2rem;">
        <div class="card">
          <div class="card-h"><span class="card-t">📈 Ventes 7 jours</span></div>
          <div class="mini-chart" id="mchart"></div>
          <div style="display:flex;justify-content:space-between;padding:.7rem 1.5rem;font-size:.72rem;color:var(--muted);border-top:1px solid var(--border);">
            <span>Commandes par jour</span>
            <span style="color:var(--green);font-weight:800">↑ +23% cette semaine</span>
          </div>
        </div>
        <div class="card">
          <div class="card-h"><span class="card-t">🔥 Statuts en temps réel</span></div>
          <div style="padding:1rem;" id="statusDonut"></div>
        </div>
      </div>
      <div class="card">
        <div class="card-h">
          <span class="card-t">🆕 Nouvelles commandes à affecter</span>
          <div class="card-acts">
            <span id="newCount" style="font-size:.78rem;font-weight:800;color:var(--red)"></span>
            <button class="btn btn-gold" onclick="affecterTout()">⚡ Affecter tout auto</button>
          </div>
        </div>
        <div class="tbl-wrap">
          <table>
            <thead><tr><th>#</th><th>Heure</th><th>Client</th><th>Téléphone</th><th>Produit</th><th>Ville</th><th>Montant</th><th>Paiement</th><th>Statut</th><th>Agent affecté</th><th>Actions</th></tr></thead>
            <tbody id="newOrdersTbl"></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Toutes commandes -->
    <div class="page" id="pg-all">
      <div class="card">
        <div class="card-h">
          <span class="card-t">📦 Toutes les commandes</span>
          <div class="card-acts">
            <button class="btn btn-green" onclick="exportWA()">💬 WhatsApp</button>
            <button class="btn btn-outline" onclick="exportCSV()">📥 CSV</button>
          </div>
        </div>
        <div class="filters">
          <input class="fi search" type="text" placeholder="🔍 Rechercher..." oninput="filterAll(this.value)">
          <select class="fi" onchange="filterAllStatus(this.value)">
            <option value="all">Tous statuts</option>
            <option value="Nouvelle">🆕 Nouvelle</option>
            <option value="Affectée">🎯 Affectée</option>
            <option value="Confirmée">✅ Confirmée</option>
