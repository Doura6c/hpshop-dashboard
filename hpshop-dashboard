<!-- TOAST -->
<div class="toast" id="toastEl"></div>

<script>
// ══════════════════════════════════════════
// DONNÉES
// ══════════════════════════════════════════
const USERS = [
  {id:"manager",pass:"hp2026",name:"Directeur HPSHOP",role:"manager",color:"#a06800"},
  {id:"super",pass:"hp2026",name:"Superviseur Général",role:"super",color:"#7C3AED"},
  {id:"agent01",pass:"hp2026",name:"Mamadou Bah",role:"agent",color:"#E8001C"},
  {id:"agent02",pass:"hp2026",name:"Fatoumata Diallo",role:"agent",color:"#1A8A2E"},
  {id:"agent03",pass:"hp2026",name:"Ibrahima Sow",role:"agent",color:"#3B82F6"},
  {id:"agent04",pass:"hp2026",name:"Aïssatou Camara",role:"agent",color:"#8B5CF6"},
  {id:"agent05",pass:"hp2026",name:"Seydou Kouyaté",role:"agent",color:"#F97316"},
  {id:"agent06",pass:"hp2026",name:"Kadiatou Barry",role:"agent",color:"#EC4899"},
];

const AGENTS = USERS.filter(u=>u.role==="agent");

const STATUTS_ALL = [
  {key:"Nouvelle",label:"🆕 Nouvelle",cls:"b-new"},
  {key:"Affectée",label:"🎯 Affectée",cls:"b-affect"},
  {key:"Confirmée",label:"✅ Confirmée",cls:"b-confirm"},
  {key:"En livraison",label:"🚚 En livraison",cls:"b-livraison"},
  {key:"Livrée",label:"📬 Livrée",cls:"b-livre"},
  {key:"Reportée",label:"⏳ Reportée",cls:"b-reporte"},
  {key:"Injoignable",label:"📵 Injoignable",cls:"b-injoignable"},
  {key:"Annulée",label:"❌ Annulée",cls:"b-annule"},
];

const PRODUITS=[
  {nom:"Fer à Lisser Pro",emoji:"💇‍♀️",prix:185000},
  {nom:"Montre GPS Sport",emoji:"⌚",prix:210000},
  {nom:"Climatiseur Portable",emoji:"❄️",prix:250000},
  {nom:"Drone 4K Pliable",emoji:"🚁",prix:240000},
  {nom:"Robot Cuiseur 5L",emoji:"🍳",prix:220000},
  {nom:"Blender Pro 1500W",emoji:"🥤",prix:185000},
  {nom:"Purificateur Air UV",emoji:"💨",prix:200000},
  {nom:"Masseur Pistolet",emoji:"💪",prix:200000},
  {nom:"Vélo Appartement",emoji:"🚴",prix:245000},
  {nom:"Kit Soin Visage 5en1",emoji:"✨",prix:200000},
];

const VILLES=["Conakry","Conakry","Conakry","Kindia","Labé","Kankan","Mamou"];
const NOMS=["Fatoumata K.","Mamadou B.","Aïssatou M.","Seydou D.","Kadiatou S.","Ibrahim C.","Mariama T.","Oumar L.","Aminata F.","Boubacar D."];
const PAYS=["Cash livraison","Orange Money","Soutrat Money","MTN MoMo","Wave"];
const QUARTIERS=["Ratoma","Kaloum","Matam","Dixinn","Matoto","Centre ville"];

// Générer commandes
let orders=[];
const statutsDist=["Nouvelle","Nouvelle","Nouvelle","Affectée","Confirmée","En livraison","Livrée","Reportée","Injoignable","Annulée"];
for(let i=1;i<=40;i++){
  const p=PRODUITS[Math.floor(Math.random()*PRODUITS.length)];
  const st=statutsDist[Math.floor(Math.random()*statutsDist.length)];
  const agent=st!=="Nouvelle"?AGENTS[Math.floor(Math.random()*AGENTS.length)]:null;
  const h=String(Math.floor(Math.random()*10)+8).padStart(2,"0");
  const m=String(Math.floor(Math.random()*60)).padStart(2,"0");
  orders.push({
    id:"HP"+String(i).padStart(4,"0"),
    date:`26/04/2026 ${h}:${m}`,
    client:NOMS[Math.floor(Math.random()*NOMS.length)],
    tel:`6${Math.floor(Math.random()*3)+2}${String(Math.floor(Math.random()*9000000)+1000000)}`,
    produit:p.nom, emoji:p.emoji, prix:p.prix,
    ville:VILLES[Math.floor(Math.random()*VILLES.length)],
    adresse:"Quartier "+QUARTIERS[Math.floor(Math.random()*QUARTIERS.length)],
    paiement:PAYS[Math.floor(Math.random()*PAYS.length)],
    statut:st,
    agent:agent?agent.id:null,
    agentName:agent?agent.name:null,
    note:"",
    prio:Math.random()>.7?"high":Math.random()>.5?"mid":"low"
  });
}

let currentUser=null;
let pickedAgent=null;
let pickedStatus=null;
let targetOrderId=null;
let displayOrders=[...orders];

// ══════════════════════════════════════════
// LOGIN
// ══════════════════════════════════════════
function doLogin(){
  const u=document.getElementById("lu").value.trim();
  const p=document.getElementById("lp").value.trim();
  const user=USERS.find(x=>x.id===u&&x.pass===p);
  if(!user){toast("❌ Identifiant ou mot de passe incorrect","error");return;}
  currentUser=user;
  document.getElementById("loginScreen").style.display="none";
  document.getElementById("app").style.display="grid";
  setupUser();
}
document.addEventListener("keydown",e=>{if(e.key==="Enter"&&!document.getElementById("loginScreen").style.display||document.getElementById("loginScreen").style.display==="flex")doLogin();});

function logout(){
  currentUser=null;
  document.getElementById("loginScreen").style.display="flex";
  document.getElementById("app").style.display="none";
  document.getElementById("lu").value="";
  document.getElementById("lp").value="";
}

// ══════════════════════════════════════════
// SETUP SELON RÔLE
// ══════════════════════════════════════════
function setupUser(){
  const u=currentUser;
  const initials=u.name.split(" ").map(n=>n[0]).join("").slice(0,2).toUpperCase();
  document.getElementById("sbAv").textContent=initials;
  document.getElementById("sbAv").style.background=`linear-gradient(135deg,${u.color},${u.color}88)`;
  document.getElementById("sbName").textContent=u.name;
  document.getElementById("sbRole").textContent={manager:"👔 Manager",agent:"🧑 Agent",super:"📊 Superviseur"}[u.role];
  const tagEl=document.getElementById("tbRoleTag");
  tagEl.textContent={manager:"Manager",agent:"Agent",super:"Superviseur"}[u.role];
  tagEl.className="tb-role-tag "+{manager:"tag-manager",agent:"tag-agent",super:"tag-super"}[u.role];

  if(u.role==="manager") setupManager();
  else if(u.role==="agent") setupAgent();
  else setupSuper();
}

// ══════════════════════════════════════════
// MANAGER
// ══════════════════════════════════════════
function setupManager(){
  document.getElementById("sbNav").innerHTML=`
    <div class="sb-sec">Principal</div>
    <div class="sb-link on" onclick="showPg('dashboard',this)"><span class="sb-ico">📊</span>Tableau de bord<span class="sb-badge" id="newBadge">${orders.filter(o=>o.statut==="Nouvelle").length}</span></div>
    <div class="sb-link" onclick="showPg('all',this)"><span class="sb-ico">📦</span>Toutes commandes</div>
    <div class="sb-sec">Équipe</div>
    <div class="sb-link" onclick="showPg('agents',this)"><span class="sb-ico">👥</span>Performance agents</div>
    <div class="sb-sec">Opérations</div>
    <div class="sb-link" onclick="showPg('stock',this)"><span class="sb-ico">🏪</span>Stock produits</div>`;
  renderManagerDash();
  renderAllOrders(orders);
  renderPerf();
  renderStock();
  populateAgentFilter();
}

function renderManagerDash(){
  const total=orders.length;
  const nouvelles=orders.filter(o=>o.statut==="Nouvelle").length;
  const encours=orders.filter(o=>["Affectée","Confirmée","En livraison"].includes(o.statut)).length;
  const livrees=orders.filter(o=>o.statut==="Livrée").length;
  const pb=orders.filter(o=>["Reportée","Injoignable","Annulée"].includes(o.statut)).length;
  const ca=orders.filter(o=>o.statut==="Livrée").reduce((s,o)=>s+o.prix,0);

  document.getElementById("statsGrid").innerHTML=`
    <div class="sc sc-blue"><div class="sc-ico">📦</div><div class="sc-val">${total}</div><div class="sc-lbl">Total commandes</div></div>
    <div class="sc sc-red"><div class="sc-ico">🆕</div><div class="sc-val">${nouvelles}</div><div class="sc-lbl">À affecter</div><div class="sc-trend dn">⚠️ Urgent</div></div>
    <div class="sc sc-gold"><div class="sc-ico">⚙️</div><div class="sc-val">${encours}</div><div class="sc-lbl">En cours</div></div>
    <div class="sc sc-green"><div class="sc-ico">📬</div><div class="sc-val">${livrees}</div><div class="sc-lbl">Livrées</div><div class="sc-trend up">↑ ${Math.round(livrees/total*100)}% taux</div></div>
    <div class="sc sc-purple"><div class="sc-ico">💰</div><div class="sc-val">${(ca/1000000).toFixed(1)}M</div><div class="sc-lbl">CA GNF</div></div>`;

  // Mini chart
  const days=["Lun","Mar","Mer","Jeu","Ven","Sam","Auj"];
  const vals=[5,8,6,12,9,15,nouvelles];
  const max=Math.max(...vals);
  document.getElementById("mchart").innerHTML=vals.map((v,i)=>`
    <div class="mc-bar-w">
      <div class="mc-bar" style="height:${Math.max(4,(v/max)*70)}px;background:${i===6?"var(--red)":"linear-gradient(to top,var(--red),var(--gold))"}"></div>
      <div class="mc-lbl">${days[i]}</div>
    </div>`).join("");

  // Status donut simple
  const statusCounts={};
  STATUTS_ALL.forEach(s=>{statusCounts[s.key]=orders.filter(o=>o.statut===s.key).length;});
  document.getElementById("statusDonut").innerHTML=STATUTS_ALL.filter(s=>statusCounts[s.key]>0).map(s=>`
    <div style="display:flex;align-items:center;justify-content:space-between;padding:.4rem 0;border-bottom:1px solid var(--border);">
      <span class="badge ${s.cls}">${s.label}</span>
      <span style="font-family:Bebas Neue,sans-serif;font-size:1.1rem;color:var(--dark)">${statusCounts[s.key]}</span>
    </div>`).join("");

  // Nouvelles commandes
  const news=orders.filter(o=>o.statut==="Nouvelle");
  document.getElementById("newCount").textContent=news.length+" commande(s) à affecter";
  document.getElementById("newOrdersTbl").innerHTML=news.length?news.map(o=>managerRow(o)).join(""):`<tr><td colspan="11"><div class="empty"><div class="empty-ico">✅</div><p>Toutes les commandes sont affectées !</p></div></td></tr>`;
}

function managerRow(o){
  const st=STATUTS_ALL.find(s=>s.key===o.statut)||STATUTS_ALL[0];
  return `<tr>
    <td><span class="prio prio-${o.prio}"></span><b style="color:var(--red)">${o.id}</b></td>
    <td style="font-size:.75rem">${o.date}</td>
    <td><b>${o.client}</b></td>
    <td style="font-size:.78rem">${o.tel}</td>
    <td>${o.emoji} ${o.produit}</td>
    <td>${o.ville}</td>
    <td style="font-family:Bebas Neue,sans-serif;font-size:1.1rem;color:var(--red)">${o.prix.toLocaleString("fr")} GNF</td>
    <td style="font-size:.75rem">${o.paiement}</td>
    <td><span class="badge ${st.cls}">${st.label}</span></td>
    <td style="font-size:.75rem">${o.agentName||'<span style="color:var(--muted);font-style:italic">Non affecté</span>'}</td>
    <td>
      <div style="display:flex;gap:.3rem;">
        <button class="btn btn-gold" style="font-size:.65rem;padding:5px 10px" onclick="openAffect('${o.id}')">🎯 Affecter</button>
        <button class="btn btn-outline" style="font-size:.65rem;padding:5px 10px" onclick="openStatus('${o.id}')">✏️</button>
        <button class="btn btn-green" style="font-size:.65rem;padding:5px 10px" onclick="sendWA('${o.id}')">💬</button>
      </div>
    </td>
  </tr>`;
}

// ══════════════════════════════════════════
// AFFECTATION
// ══════════════════════════════════════════
function openAffect(id){
  const o=orders.find(x=>x.id===id);
  if(!o)return;
  targetOrderId=id; pickedAgent=null;
  document.getElementById("affectId").textContent=id;
  document.getElementById("affectDetail").innerHTML=`
    <div class="df"><label>Client</label><span>${o.client}</span></div>
    <div class="df"><label>Téléphone</label><span>${o.tel}</span></div>
    <div class="df"><label>Produit</label><span>${o.emoji} ${o.produit}</span></div>
    <div class="df"><label>Montant</label><span style="color:var(--red);font-weight:800">${o.prix.toLocaleString("fr")} GNF</span></div>
    <div class="df"><label>Ville</label><span>${o.ville}</span></div>
    <div class="df"><label>Paiement</label><span>${o.paiement}</span></div>`;

  // Afficher agents avec leur charge
  document.getElementById("agentSelectGrid").innerHTML=AGENTS.map(a=>{
    const charge=orders.filter(x=>x.agent===a.id&&["Affectée","Confirmée"].includes(x.statut)).length;
    const initials=a.name.split(" ").map(n=>n[0]).join("").slice(0,2);
    return `<div class="agent-opt" id="opt-${a.id}" onclick="pickAgent('${a.id}')">
      <div class="agent-opt-av" style="background:linear-gradient(135deg,${a.color},${a.color}88)">${initials}</div>
      <div>
        <div class="agent-opt-name">${a.name}</div>
        <div class="agent-opt-info">${a.id}</div>
        <div class="agent-opt-load" style="color:${charge>5?"var(--red)":charge>3?"var(--orange)":"var(--green)"}">${charge} commandes en cours</div>
      </div>
    </div>`;
  }).join("");
  document.getElementById("affectModal").classList.add("show");
}

function pickAgent(id){
  pickedAgent=id;
  document.querySelectorAll(".agent-opt").forEach(el=>el.classList.remove("picked"));
  document.getElementById("opt-"+id).classList.add("picked");
}

function confirmAffect(){
  if(!pickedAgent){toast("⚠️ Choisissez un agent","warn");return;}
  const o=orders.find(x=>x.id===targetOrderId);
  const agent=AGENTS.find(a=>a.id===pickedAgent);
  o.statut="Affectée"; o.agent=pickedAgent; o.agentName=agent.name;
  closeModals();
  renderManagerDash();
  renderAllOrders(orders);
  toast(`✅ Commande ${targetOrderId} affectée à ${agent.name}`,"success");
  // Simuler notif WA
  setTimeout(()=>toast(`💬 Notification envoyée à ${agent.name}`,"success"),1500);
}

function affecterTout(){
  const news=orders.filter(o=>o.statut==="Nouvelle");
  if(!news.length){toast("✅ Aucune commande à affecter","success");return;}
  let i=0;
  news.forEach(o=>{
    const agent=AGENTS[i%AGENTS.length];
    o.statut="Affectée"; o.agent=agent.id; o.agentName=agent.name;
    i++;
  });
  renderManagerDash();
  renderAllOrders(orders);
  toast(`⚡ ${news.length} commandes affectées automatiquement !`,"success");
}

// ══════════════════════════════════════════
// STATUT UPDATE
// ══════════════════════════════════════════
function openStatus(id){
  const o=orders.find(x=>x.id===id);
  if(!o)return;
  targetOrderId=id; pickedStatus=null;
  document.getElementById("statusOrderId").textContent=id;
  document.getElementById("statusDetail").innerHTML=`
    <div class="df"><label>Client</label><span>${o.client}</span></div>
    <div class="df"><label>Produit</label><span>${o.emoji} ${o.produit}</span></div>`;
  document.getElementById("statusNote").value=o.note||"";

  const agentStatuts=currentUser.role==="agent"
    ?["Confirmée","En livraison","Livrée","Reportée","Injoignable","Annulée"]
    :["Confirmée","En livraison","Livrée","Reportée","Injoignable","Annulée"];

  document.getElementById("statusGrid").innerHTML=agentStatuts.map(s=>{
    const cls={Confirmée:"so-confirm",Livrée:"so-livre",Reportée:"so-reporte",Annulée:"so-annule",Injoignable:"so-injoignable","En livraison":"so-livraison"}[s];
    const ico={Confirmée:"✅",Livrée:"📬",Reportée:"⏳",Annulée:"❌",Injoignable:"📵","En livraison":"🚚"}[s];
    return `<div class="status-opt ${cls}" onclick="pickStatus(this,'${s}')">${ico} ${s}</div>`;
  }).join("");
  document.getElementById("statusModal").classList.add("show");
}

function pickStatus(el,s){
  pickedStatus=s;
  document.querySelectorAll(".status-opt").forEach(e=>e.classList.remove("picked"));
  el.classList.add("picked");
}

function confirmStatus(){
  if(!pickedStatus){toast("⚠️ Choisissez un statut","warn");return;}
  const o=orders.find(x=>x.id===targetOrderId);
  o.statut=pickedStatus;
  o.note=document.getElementById("statusNote").value;
  closeModals();
  if(currentUser.role==="manager"){renderManagerDash();renderAllOrders(orders);}
  else if(currentUser.role==="agent"){renderAgentKanban();}
  else{renderSuper();}
  toast(`✅ Commande ${targetOrderId} → ${pickedStatus}`,"success");
}

// ══════════════════════════════════════════
// ALL ORDERS TABLE
// ══════════════════════════════════════════
function renderAllOrders(list){
  const st=s=>STATUTS_ALL.find(x=>x.key===s)||{label:s,cls:"b-new"};
  document.getElementById("allOrdersTbl").innerHTML=list.map(o=>`<tr>
    <td><b style="color:var(--red)">${o.id}</b></td>
    <td style="font-size:.72rem">${o.date}</td>
    <td><b>${o.client}</b></td>
    <td style="font-size:.75rem">${o.tel}</td>
    <td style="font-size:.8rem">${o.emoji} ${o.produit}</td>
    <td>${o.ville}</td>
    <td style="font-family:Bebas Neue,sans-serif;font-size:1rem;color:var(--red)">${o.prix.toLocaleString("fr")}</td>
