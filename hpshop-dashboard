      ${colOrders.length?colOrders.map(o=>`
        <div class="order-mini" style="border-left-color:${col.color}" onclick="openStatus('${o.id}')">
          <div class="om-id">${o.id} · ${o.date.split(" ")[1]}</div>
          <div class="om-client">👤 ${o.client}</div>
          <div style="font-size:.72rem;color:var(--muted)">📞 ${o.tel}</div>
          <div class="om-produit">${o.emoji} ${o.produit}</div>
          <div style="font-size:.72rem;color:var(--muted)">📍 ${o.ville} — ${o.adresse}</div>
          <div style="font-size:.72rem;color:var(--muted)">💳 ${o.paiement}</div>
          <div class="om-prix">${o.prix.toLocaleString("fr")} GNF</div>
          ${o.note?`<div style="font-size:.7rem;color:var(--orange);margin-top:.3rem">📝 ${o.note}</div>`:""}
          <div style="display:flex;gap:.4rem;margin-top:.5rem;">
            <button class="btn btn-outline" style="font-size:.62rem;padding:4px 8px" onclick="event.stopPropagation();openStatus('${o.id}')">✏️ Statut</button>
